---
// src/layouts/Layout.astro
import '../styles/global.css'; // <-- ESTA LÍNEA ES LA CLAVE PARA QUE ACTIVE TAILWIND GLOBALMENTE

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Flavor Land - Snacks saludables y frituras artesanales." />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/webp" href="/images/logotipo.webp" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		
		<!-- Google Fonts Oficial para Opción 1 -->
		<link rel="preconnect" href="https://googleapis.com">
		<link rel="preconnect" href="https://gstatic.com" crossorigin>
		<link href="https://googleapis.com/css2?family=Lilita+One&family=Quicksand:wght@400;500;700&display=swap" rel="stylesheet">
	</head>
	<body class="bg-brand-bg-cream font-body text-brand-dark min-h-screen antialiased">
		<slot />
	</body>
</html>
