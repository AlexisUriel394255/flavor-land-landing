---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import ProductGrid from '../components/ProductGrid.jsx';
import Footer from '../components/Footer.astro'; // <-- 1. IMPORTAMOS EL FOOTER AQUÍ
import '../styles/global.css'; 
---

<Layout title="Flavor Land | Sabor que te hace bien">
  <!-- Cabecera Premium con Logotipo integrado (Se mantiene intacta) -->
  <header class="bg-brand-bg-cream/90 backdrop-blur-md sticky top-0 z-50 border-b border-brand-green-dark/10 px-4 py-3">
    <div class="max-w-6xl mx-auto flex justify-between items-center">
      <a href="#" class="flex items-center gap-3 hover:opacity-90 transition-opacity">
        <img 
          src="/images/logotipo.webp" 
          alt="Flavor Land Logo Mini" 
          class="h-12 w-auto object-contain"
          width="48"
          height="48"
        />
        <span class="font-heading text-xl md:text-2xl text-brand-green-dark tracking-wider">FLAVOR LAND</span>
      </a>
      <nav class="hidden sm:flex gap-6 font-body font-bold text-brand-green-dark/80">
        <a href="#productos" class="hover:text-brand-green-light transition-colors">Productos</a>
        <a href="#beneficios" class="hover:text-brand-green-light transition-colors">Beneficios</a>
        <a href="#contacto" class="hover:text-brand-green-light transition-colors">Contacto</a>
      </nav>
    </div>
  </header>

  <main>
    <!-- Sección de Bienvenida estilizada -->
    <Hero />
    
    {/* Cintillo de Beneficios Destacados */}
    <div id="beneficios" class="bg-brand-green-dark text-brand-bg-cream py-6 my-4 shadow-inner">
      <div class="max-w-6xl mx-auto px-4 flex flex-wrap justify-around text-center gap-6 font-heading text-lg md:text-xl tracking-wide">
        <div>🌱 SIN CONSERVADORES</div>
        <div>💨 SIN FREÍR</div>
        <div>🤤 100% DELICIOSAS</div>
      </div>
    </div>

    <!-- Catálogo Interactivo en React -->
    <ProductGrid client:load />
  </main>

  <!-- 2. INSERTAMOS EL FOOTER AL FINAL DE LA PÁGINA -->
  <Footer />
</Layout>
