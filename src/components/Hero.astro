---
// src/components/Hero.astro
---
<section class="relative bg-brand-bg-cream py-12 md:py-20 px-4 overflow-hidden border-b border-brand-green-dark/5 min-h-[75vh] flex items-center">
  <div class="absolute inset-0 bg-[radial-gradient(#60a62e_1px,transparent_1px)] [background-size:24px_24px] opacity-5 pointer-events-none"></div>

  <div class="max-w-6xl mx-auto w-full grid grid-cols-1 md:grid-cols-12 gap-12 items-center relative z-10">
    
    <!-- Bloque Izquierdo: Textos con Estilo Bangers Urbano -->
    <div class="md:col-span-7 text-center md:text-left space-y-6">
      <span class="inline-flex items-center gap-2 bg-brand-green-light/10 text-brand-green-dark font-body font-bold px-4 py-1.5 rounded-full text-sm border border-brand-green-light/20 tracking-wide">
        🍿 SNACKS FIT & 100% NATURALES
      </span>
      
      <!-- Forzamos la tipografía Bangers, Mayúsculas, Grueso y tracking ancho -->
      <h1 class="font-heading text-6xl md:text-8xl text-brand-green-dark uppercase tracking-wide leading-none select-none">
        EL SABOR QUE TE <br />
        <span class="text-brand-betabel drop-shadow-sm bg-brand-betabel/5 px-4 py-1 rounded-2xl inline-block mt-2">HACE BIEN</span>
      </h1>
      
      <p class="font-body text-base md:text-lg text-brand-dark/80 max-w-xl leading-relaxed font-medium">
        Disfruta de crujientes frituras artesanales sin culpas. Botanas de jícama, betabel, plátano y camote deshidratadas, <span class="text-brand-green-light font-bold">¡sin freír y sin procesos químicos!</span>
      </p>
      
      <div class="pt-2 flex flex-col sm:flex-row gap-4 justify-center md:justify-start items-center">
        <a 
          href="#productos" 
          class="inline-block bg-brand-camote hover:bg-brand-camote/90 text-white font-heading text-2xl px-12 py-4 rounded-xl shadow-lg shadow-brand-camote/30 transition-all duration-300 hover:-translate-y-1 tracking-wider text-center w-full sm:w-auto uppercase"
        >
          ¡PROBAR AHORA!
        </a>
        
        <div class="flex gap-3 text-sm font-body font-bold text-brand-green-dark/80 uppercase tracking-wider">
          <span>🌱 Orgánico</span>
          <span>•</span>
          <span>🔥 Sin Freír</span>
        </div>
      </div>
    </div>

    <!-- Bloque Derecho -->
    <div class="md:col-span-5 flex justify-center relative min-h-[350px]">
      <img src="/images/logotipo.webp" alt="Flavor Land Logo" class="w-full max-w-[340px] h-auto object-contain opacity-80 drop-shadow-xl" loading="eager" />
      <img src="/images/betabeladobado.webp" alt="Betabel Adobado" class="absolute -left-4 bottom-0 w-32 h-auto object-contain drop-shadow-lg transform -rotate-12 hover:scale-110 transition-transform duration-300 hidden sm:block" loading="eager" />
      <img src="/images/camoteadobado.webp" alt="Camote Adobado" class="absolute -right-4 top-4 w-32 h-auto object-contain drop-shadow-lg transform rotate-12 hover:scale-110 transition-transform duration-300 hidden sm:block" loading="eager" />
    </div>

  </div>
</section>
