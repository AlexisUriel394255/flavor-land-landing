---
// src/components/Hero.astro
---
<section class="relative bg-brand-bg-cream py-12 md:py-20 px-4 overflow-hidden border-b border-brand-green-dark/5 min-h-[75vh] flex items-center">
  <!-- Fondo decorativo sutil -->
  <div class="absolute inset-0 bg-[radial-gradient(#60a62e_1px,transparent_1px)] [background-size:24px_24px] opacity-5 pointer-events-none"></div>

  <div class="max-w-6xl mx-auto w-full grid grid-cols-1 md:grid-cols-12 gap-12 items-center relative z-10">
    
    <!-- Bloque Izquierdo: Textos -->
    <div class="md:col-span-7 text-center md:text-left space-y-6">
      <span class="inline-flex items-center gap-2 bg-brand-green-light/10 text-brand-green-dark font-body font-bold px-4 py-1.5 rounded-full text-sm border border-brand-green-light/20 tracking-wide">
        🍿 Snacks Fit & 100% Naturales
      </span>
      
      <h1 class="font-heading text-5xl md:text-7xl text-brand-green-dark leading-[1.1] tracking-wide">
        El sabor que te <br />
        <span class="text-brand-betabel drop-shadow-sm bg-brand-betabel/5 px-3 py-0.5 rounded-xl inline-block">hace bien</span>
      </h1>
      
      <p class="font-body text-lg md:text-xl text-brand-dark/80 max-w-xl leading-relaxed font-semibold">
        Disfruta de crujientes frituras artesanales sin culpas. Botanas de jícama, betabel, plátano y camote deshidratadas, <span class="text-brand-green-light font-bold">¡sin freír y sin procesos químicos!</span>
      </p>
      
      <div class="pt-2 flex flex-col sm:flex-row gap-4 justify-center md:justify-start items-center">
        <a 
          href="#productos" 
          class="inline-block bg-brand-camote hover:bg-brand-camote/90 text-white font-heading text-xl px-10 py-4 rounded-xl shadow-lg shadow-brand-camote/30 transition-all duration-300 hover:-translate-y-1 tracking-wider text-center w-full sm:w-auto"
        >
          ¡PROBAR AHORA!
        </a>
        
        <div class="flex gap-3 text-sm font-body font-bold text-brand-green-dark/80">
          <span>🌱 Orgánico</span>
          <span>•</span>
          <span>🔥 Sin Freír</span>
        </div>
      </div>
    </div>

    <!-- Bloque Derecho: Composición Visual (Logo + Productos) -->
    <div class="md:col-span-5 flex justify-center relative min-h-[350px]">
      <!-- Logotipo de fondo -->
      <img 
        src="/images/logotipo.webp" 
        alt="Flavor Land Logo" 
        class="w-full max-w-[340px] h-auto object-contain opacity-80 drop-shadow-xl"
        loading="eager"
      />
      
      <!-- Producto flotante izquierda (Betabel) -->
      <img 
        src="/images/betabeladobado.webp" 
        alt="Betabel Adobado" 
        class="absolute -left-4 bottom-0 w-32 h-auto object-contain drop-shadow-lg transform -rotate-12 hover:scale-110 transition-transform duration-300 hidden sm:block"
        loading="eager"
      />

      <!-- Producto flotante derecha (Camote) -->
      <img 
        src="/images/camoteadobado.webp" 
        alt="Camote Adobado" 
        class="absolute -right-4 top-4 w-32 h-auto object-contain drop-shadow-lg transform rotate-12 hover:scale-110 transition-transform duration-300 hidden sm:block"
        loading="eager"
      />
    </div>

  </div>
</section>
