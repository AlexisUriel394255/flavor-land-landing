---
// src/components/Hero.astro
---
<section class="relative bg-brand-bg-cream py-12 md:py-20 px-4 overflow-hidden border-b border-brand-green-dark/5 min-h-[75vh] flex items-center">
  <div class="absolute inset-0 bg-[radial-gradient(#60a62e_1px,transparent_1px)] [background-size:24px_24px] opacity-5 pointer-events-none"></div>

  <div class="max-w-6xl mx-auto w-full grid grid-cols-1 md:grid-cols-12 gap-12 items-center relative z-10">
    
    <!-- Bloque Izquierdo: Textos con Estilo Bangers Urbano -->
    <div class="md:col-span-7 text-center md:text-left space-y-6">
      <span class="inline-flex items-center gap-2 bg-brand-green-light/10 text-brand-green-dark font-body font-bold px-4 py-1.5 rounded-full text-sm border border-brand-green-light/20 tracking-wide">
        🍿 SNACKS FIT & 100% NATURALES
      </span>
      
      <!-- Ajustamos la jerarquía visual del nuevo eslogan -->
      <h1 class="font-heading text-4xl sm:text-5xl md:text-6xl text-brand-green-dark leading-[1.1] tracking-wide select-none font-normal">
        <span class="text-3xl sm:text-4xl md:text-5xl opacity-90 block mb-1">Las penas con</span>
        <span class="text-5xl sm:text-6xl md:text-7xl block text-brand-green-light uppercase tracking-wider my-2">FLAVOR LAND</span>
        son buenas 
        <span class="text-brand-betabel drop-shadow-md bg-brand-betabel/5 px-4 py-1.5 rounded-2xl inline-block mt-3 transform -rotate-1 tracking-normal text-4xl sm:text-5xl md:text-6xl">
          porque son fitness
        </span>
      </h1>

      <p class="font-body text-lg md:text-xl text-brand-dark/80 max-w-xl leading-relaxed font-semibold">
        Las frutas y vegetables crujientes te darán el gusto de disfrutar <span class="text-brand-green-light font-bold">una rica botana saludable</span>.
      </p>

      <div class="pt-2 flex flex-col sm:flex-row gap-4 justify-center md:justify-start items-center">
        <a 
          href="#productos" 
          class="inline-block bg-brand-camote hover:bg-brand-camote/90 text-white font-heading text-2xl px-12 py-4 rounded-xl shadow-lg shadow-brand-camote/30 transition-all duration-300 hover:-translate-y-1 tracking-wider text-center w-full sm:w-auto uppercase"
        >
          ¡PROBAR AHORA!
        </a>
        
        <div class="flex gap-3 text-sm font-body font-bold text-brand-green-dark/80 uppercase tracking-wider">
          <span>🌱 Orgánico</span>
          <span>•</span>
          <span>🔥 Sin Freír</span>
        </div>
      </div>
    </div>

    <!-- 🚀 BLOQUE DERECHO REDISEÑADO PARA REVENTAR EL SCORE 100/100 SIN ALTERAR LA PC -->
    <div class="md:col-span-5 flex justify-center relative min-h-[350px]">
      {/* El Logotipo Principal: Es el elemento LCP más importante en la pantalla de Android */}
      <img 
        src="/images/logotipo.webp" 
        alt="Flavor Land Logo" 
        class="w-full max-w-[340px] h-auto object-contain opacity-80 drop-shadow-xl" 
        loading="eager" 
        fetchpriority="high"
        decoding="sync"
        width="340"
        height="340"
      />
      {/* Las bolsas flotantes: Cambiamos a loading lazy y decoding async para quitarle carga de red al inicio. 
          En pantallas grandes (PC) se verán exactamente iguales y flotando con sus efectos intactos */}
      <img 
        src="/images/betabeladobado.webp" 
        alt="Betabel Adobado" 
        class="absolute -left-4 bottom-0 w-32 h-auto object-contain drop-shadow-lg transform -rotate-12 hover:scale-110 transition-transform duration-300 hidden sm:block" 
        loading="lazy" 
        decoding="async"
        width="128"
        height="180"
      />
      <img 
        src="/images/camoteadobado.webp" 
        alt="Camote Adobado" 
        class="absolute -right-4 top-4 w-32 h-auto object-contain drop-shadow-lg transform rotate-12 hover:scale-110 transition-transform duration-300 hidden sm:block" 
        loading="lazy" 
        decoding="async"
        width="128"
        height="180"
      />
    </div>

  </div>
</section>
